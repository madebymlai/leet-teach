#!/usr/bin/env bash
# leetcode-mcp — launcher that reads the LeetCode session from ~/.leetcode/leetcode.toml
# (single source of truth) and execs the MCP server. MCP configs point to this script,
# never to the cookie value directly.
# Installed as a symlink, so it resolves its real dir to source the shared toml reader.

LEET_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=leet-toml.sh
source "$LEET_DIR/leet-toml.sh"
# shellcheck source=leet-cookies.sh
source "$LEET_DIR/leet-cookies.sh"

# --- pure helpers (no I/O, testable) ---

map_site() {
    local site_raw="$1"
    case "$site_raw" in
        leetcode.cn|cn) printf 'cn' ;;
        *)              printf 'global' ;;
    esac
}

# --- execute guard (skipped when sourced for tests) ---

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail

    LC_TOML="$(toml_path)"

    [ -f "$LC_TOML" ] || {
        echo "leetcode-mcp: $LC_TOML not found. Run scripts/setup.sh first." >&2
        exit 1
    }

    # Best-effort: the server reads the cookie once at startup and can't retry on a
    # stale session mid-run (unlike `leet test`/`submit`), so refresh from the browser
    # now. cookies_sync writes status to stderr only, keeping stdout protocol-clean;
    # on failure (browser closed, not logged in) we fall back to the stored cookie.
    # Opt out with LEET_MCP_NO_SYNC=1.
    [ "${LEET_MCP_NO_SYNC:-}" = 1 ] || cookies_sync "$LC_TOML" || true

    content=$(cat "$LC_TOML")
    session=$(toml_get "$content" "session")

    [ -n "$session" ] || {
        echo "leetcode-mcp: session cookie not set in $LC_TOML. Log into leetcode.com in your browser, then run: leet sync" >&2
        exit 1
    }

    site_raw=$(toml_get "$content" "site")
    mcp_site=$(map_site "$site_raw")

    export LEETCODE_SESSION="$session"
    export LEETCODE_SITE="$mcp_site"
    exec npx -y @jinzcdev/leetcode-mcp-server@latest --site "$mcp_site"
fi
