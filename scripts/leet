#!/usr/bin/env bash
# leet — LeetCode + tmux workflow wrapper.
# Strict mode + dispatch run only when executed, not when sourced (for tests).
PROG="$(basename "${0}")"
LEET_PANE_OPTION="@leet_edit_pane"
LEET_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# leetcode-cli installs to ~/.cargo/bin (setup.sh adds it to PATH, but not login shells)
export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
# shellcheck source=leet-languages.sh
source "$LEET_DIR/leet-languages.sh"
# shellcheck source=leet-toml.sh
source "$LEET_DIR/leet-toml.sh"
# shellcheck source=leet-cookies.sh
source "$LEET_DIR/leet-cookies.sh"

usage() {
    cat <<EOF
Usage: $PROG <command> [args]

LeetCode + tmux workflow wrapper.

Commands:
  pick <slug|id>    Pick a problem, then open it in the helix pane
  edit <id>        Open problem in helix pane (reuses existing pane)
  test <id>        Test solution (runs in current pane)
  submit <id>      Submit solution (runs in current pane)
  lang [name]      Show/choose problem language (picker if no arg)
  sync             Pull the live LeetCode cookie from your browser into leetcode.toml
  close            Close the helix pane

Examples:
  $PROG pick two-sum    # Pick by slug + open in helix pane
  $PROG pick 1          # Pick by ID + open in helix pane
  $PROG edit 1          # Switch to problem 1 in existing helix pane
  $PROG test 1          # Run tests
  $PROG submit 1        # Submit solution
  $PROG lang            # Pick language from menu
  $PROG lang rust       # Set language to rust
  $PROG sync            # Refresh the LeetCode cookie from your browser
  $PROG close           # Close helix pane

Tmux layout:
  Left:  AI agent session (opencode/claude/codex)
  Right: helix editor (opened by this script)
EOF
}

die() { echo "$PROG: $*" >&2; exit 1; }

# --- pure helpers (no I/O, testable) ---

parse_problem_id() {
    local output="$1"
    [[ $output =~ \[([0-9]+)\] ]] || return 1
    printf '%s\n' "${BASH_REMATCH[1]}"
}

# pick_args <slug|id> — arguments for `leetcode pick`, one per line.
# A numeric arg is a problem id (passed bare); anything else is a slug (needs -n).
pick_args() {
    local arg="$1"
    if [[ $arg =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$arg"
    else
        printf '%s\n%s\n' "-n" "$arg"
    fi
}

# --- edit-pane planners (pure: observed pane state → ordered steps) ---

# plan_edit <alive:yes|no> <cur_cmd> <id> — steps to make the helix pane show <id>.
plan_edit() {
    local alive="$1" cur_cmd="$2" id="$3"
    if [ "$alive" != yes ]; then
        printf 'create %s\n' "$id"
        return
    fi
    case "$cur_cmd" in
        hx|helix) printf 'quit-editor\n' ;;
        *)        printf 'interrupt\n' ;;
    esac
    printf 'edit %s\n' "$id"
}

# plan_close <alive:yes|no> <has_stored:yes|no> — teardown steps for the helix pane.
# A dead-but-stored pane id is still unset (cleared), but not killed.
plan_close() {
    local alive="$1" has_stored="$2"
    if [ "$alive" = yes ]; then printf 'kill\n'; fi
    if [ "$has_stored" = yes ]; then printf 'unset\n'; fi
}

# --- tmux queries ---

check_tmux() {
    command -v tmux >/dev/null || die "tmux not found. Install: sudo pacman -S tmux"
    [ -n "${TMUX:-}" ] || die "not inside a tmux session. Start one with: tmux"
}

require_leetcode() {
    command -v leetcode >/dev/null || die "leetcode-cli not found. Run scripts/setup.sh first."
}

# leet_pick_output <pick-args...> — run `leetcode pick`, capture stdout+stderr (stub point).
leet_pick_output() {
    leetcode pick "$@" 2>&1
}

current_session() {
    tmux display-message -p '#{session_name}'
}

stored_pane_id() {
    local session="$1" pane_id
    pane_id=$(tmux show-options -t "$session" -v "$LEET_PANE_OPTION" 2>/dev/null) || return 0
    printf '%s' "$pane_id"
}

pane_alive() {
    local session="$1" pane_id="$2"
    [ -n "$pane_id" ] && tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | grep -qx "$pane_id"
}

pane_command() {
    tmux display-message -p -t "$1" '#{pane_current_command}'
}

# run_leetcode_auth <leetcode-args...> — the auth-aware entry point for leet test/submit.
# Ensures a session exists (an empty cookie is rare; sync once from the browser, give up
# only if that can't produce one), runs leetcode streaming combined output, and on a
# stale-cookie failure re-syncs and retries once.
# is_auth_failure is the tested seam; collaborators (leetcode, cookies_sync) are stubbed
# in leet_test.sh, so the whole precondition → run → retry thread is covered.
run_leetcode_auth() {
    local toml out code
    toml=$(toml_path)
    # Precondition: a session must exist. An empty cookie (cold start) is rare; sync
    # once from the browser, and give up only if that can't produce a session.
    if ! toml_has "$(toml_load "$toml")" session; then
        echo "$PROG: no session cookie set, syncing from your browser..." >&2
        cookies_sync "$toml" \
            || die "LeetCode session cookie not set. Log into leetcode.com in your browser, then run: $PROG sync"
    fi
    # Capture as a && / || list so `leetcode` failing (e.g. a stale cookie) doesn't
    # trip `set -e` before we reach the retry decision below.
    out=$(leetcode "$@" 2>&1) && code=0 || code=$?
    printf '%s\n' "$out"
    if is_auth_failure "$code" "$out"; then
        echo "$PROG: session looks stale, re-syncing from your browser and retrying..." >&2
        if cookies_sync "$toml"; then
            leetcode "$@"
            return $?
        fi
    fi
    return "$code"
}

# --- commands ---

# apply_step <session> <pane_id> <step> [arg] — execute one planner step.
# The only place that knows the literal tmux invocations (the "how").
apply_step() {
    local session="$1" pane_id="$2" step="$3" arg="${4:-}"
    case "$step" in
        create)
            local new_id
            new_id=$(tmux split-window -h -P -F '#{pane_id}' "bash -c 'leetcode edit $arg; exec bash'")
            tmux set-option -t "$session" "$LEET_PANE_OPTION" "$new_id"
            ;;
        quit-editor)
            tmux send-keys -t "$pane_id" Escape Escape
            sleep 0.3
            tmux send-keys -t "$pane_id" ':q!' Enter
            sleep 0.3
            ;;
        interrupt)
            tmux send-keys -t "$pane_id" C-c
            sleep 0.2
            ;;
        edit)
            tmux send-keys -t "$pane_id" "leetcode edit $arg" Enter
            ;;
        kill)
            tmux kill-pane -t "$pane_id"
            ;;
        unset)
            tmux set-option -t "$session" -u "$LEET_PANE_OPTION"
            ;;
    esac
}

pane_edit() {
    local id="$1" session pane_id alive cur_cmd stepname steparg
    check_tmux
    require_leetcode
    session=$(current_session)
    pane_id=$(stored_pane_id "$session")
    if pane_alive "$session" "$pane_id"; then
        alive=yes
        cur_cmd=$(pane_command "$pane_id")
    else
        alive=no
        cur_cmd=""
    fi
    while IFS=' ' read -r stepname steparg; do
        [ -n "$stepname" ] || continue
        apply_step "$session" "$pane_id" "$stepname" "$steparg"
    done < <(plan_edit "$alive" "$cur_cmd" "$id")
}

close_pane() {
    check_tmux
    local session pane_id alive has_stored stepname steparg
    session=$(current_session)
    pane_id=$(stored_pane_id "$session")
    if pane_alive "$session" "$pane_id"; then alive=yes; else alive=no; fi
    if [ -n "$pane_id" ]; then has_stored=yes; else has_stored=no; fi
    if [ "$alive" = yes ]; then
        echo "Closed leet-edit pane"
    else
        echo "No leet-edit pane found"
    fi
    while IFS=' ' read -r stepname steparg; do
        [ -n "$stepname" ] || continue
        apply_step "$session" "$pane_id" "$stepname" "$steparg"
    done < <(plan_close "$alive" "$has_stored")
}

do_pick() {
    local arg="$1" output id args
    require_leetcode
    mapfile -t args < <(pick_args "$arg")
    output=$(leet_pick_output "${args[@]}") || { echo "$output" >&2; die "leetcode pick failed"; }
    echo "$output"
    id=$(parse_problem_id "$output") || die "could not parse problem ID from leetcode output; use '$PROG edit <id>' manually"
    echo ""
    echo "Opening problem $id in helix pane..."
    pane_edit "$id"
}

do_test() {
    local id="$1"
    require_leetcode
    run_leetcode_auth test "$id"
}

do_submit() {
    local id="$1"
    require_leetcode
    run_leetcode_auth exec "$id"
}

do_sync() {
    cookies_sync "$(toml_path)"
}

# plan_lang_change <content> <helix_name> — pure: return <content> with the language
# fields (lang, inject_before, comment_leading) set for <helix_name>, or return 1 if
# unsupported. Mirrors plan_edit: the decision/validation lives here and is testable;
# do_lang is the thin read/select/write around it.
plan_lang_change() {
    local content="$1" helix_name="$2" rec lang inject comment
    rec=$(lang_info "$helix_name") || return 1
    IFS=$'\t' read -r lang inject comment <<< "$rec"
    apply_lang_to_toml "$content" "$lang" "$inject" "$comment"
}

do_lang() {
    local chosen="${1:-}" helix_name toml content current
    require_leetcode
    toml=$(toml_path)
    content=$(toml_load "$toml") || die "leetcode.toml not found. Run scripts/setup.sh first."
    current=$(toml_get "$content" lang)

    if [ -z "$chosen" ]; then
        echo "Current language: ${current:-not set}"
        echo "Supported: ${SUPPORTED_LANGS}"
        echo ""
        PS3="Choose language (number): "
        select helix_name in $SUPPORTED_LANGS; do
            [ -n "$helix_name" ] && break
            echo "Invalid choice."
        done
        [ -n "$helix_name" ] || die "no language selected"
    else
        helix_name="$chosen"
    fi

    local updated
    updated=$(plan_lang_change "$content" "$helix_name") \
        || die "unsupported language: $helix_name. Supported: $SUPPORTED_LANGS"
    toml_store "$toml" "$updated"
    echo "Language set to $helix_name (leetcode: $(toml_get "$updated" lang), comment: $(toml_get "$updated" comment_leading))"
}

# --- execute guard (skipped when sourced for tests) ---

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
    if [ $# -lt 1 ]; then
        usage
        exit 1
    fi
    cmd="$1"
    shift
    case "$cmd" in
        pick)   [ $# -lt 1 ] && die "Usage: $PROG pick <slug>"; do_pick "$1" ;;
        edit)   [ $# -lt 1 ] && die "Usage: $PROG edit <id>"; pane_edit "$1" ;;
        test)   [ $# -lt 1 ] && die "Usage: $PROG test <id>"; do_test "$1" ;;
        submit) [ $# -lt 1 ] && die "Usage: $PROG submit <id>"; do_submit "$1" ;;
        lang)   do_lang "${1:-}" ;;
        sync)   do_sync ;;
        close)  close_pane ;;
        -h|--help|help) usage ;;
        *)      die "Unknown command: $cmd (see: $PROG --help)" ;;
    esac
fi
