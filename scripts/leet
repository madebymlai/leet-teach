#!/usr/bin/env bash
set -euo pipefail

PROG="$(basename "$0")"

usage() {
    cat <<EOF
Usage: $PROG <command> [args]

LeetCode + tmux workflow wrapper.

Commands:
  pick <id|slug>   Pick a problem, then open it in the helix pane
  edit <id>        Open problem in helix pane (reuses existing pane)
  test <id>        Test solution (runs in current pane)
  submit <id>      Submit solution (runs in current pane)
  close            Close the helix pane

Examples:
  $PROG pick two-sum       # Pick + open in helix pane
  $PROG edit 1             # Switch problem 1 in existing helix pane
  $PROG test 1             # Run tests
  $PROG submit 1           # Submit solution
  $PROG close              # Close helix pane

Tmux layout:
  Left:  AI agent session (opencode/claude/codex)
  Right: helix editor (opened by this script)

The editor pane is named 'leet-edit' and is reused across problems.
Close it with: $PROG close
EOF
}

check_tmux() {
    if ! command -v tmux &>/dev/null; then
        echo "Error: tmux not found. Install: sudo pacman -S tmux" >&2
        exit 1
    fi
    if [ -z "${TMUX:-}" ]; then
        echo "Error: not inside a tmux session. Start one with: tmux" >&2
        exit 1
    fi
}

pane_edit() {
    local id="$1"
    check_tmux
    if pane_exists; then
        tmux send-keys -t leet-edit Escape ':q!' Enter 2>/dev/null || true
        sleep 0.2
        tmux send-keys -t leet-edit "leetcode edit $id" Enter
    else
        tmux split-window -h -n leet-edit "leetcode edit $id"
    fi
}

pane_exists() {
    tmux list-panes -F '#{pane_title}' 2>/dev/null | grep -q 'leet-edit' || \
    tmux list-panas -F '#{pane_id}' -f '#{pane_title}=leet-edit' 2>/dev/null && return 0
    tmux has-session -t leet-edit 2>/dev/null && return 0
    for pane in $(tmux list-panes -F '#{pane_id}'); do
        if tmux display-message -t "$pane" -p '#{pane_title}' 2>/dev/null | grep -q 'leet-edit'; then
            return 0
        fi
    done
    return 1
}

close_pane() {
    check_tmux
    if pane_exists; then
        for pane in $(tmux list-panes -F '#{pane_id}'); do
            if tmux display-message -t "$pane" -p '#{pane_title}' 2>/dev/null | grep -q 'leet-edit'; then
                tmux kill-pane -t "$pane"
                echo "Closed leet-edit pane"
                return 0
            fi
        done
    fi
    echo "No leet-edit pane found"
}

do_pick() {
    local slug="$1"
    local output
    output=$(leetcode pick "$slug" 2>&1) || {
        echo "$output"
        echo "Error: leetcode pick failed" >&2
        exit 1
    }
    echo "$output"

    local id
    id=$(echo "$output" | grep -oP '\[\d+\]' | head -1 | grep -oP '\d+')
    if [ -z "$id" ]; then
        id=$(echo "$output" | grep -oP '^\d+' | head -1)
    fi
    if [ -z "$id" ]; then
        echo "Warning: could not parse problem ID, use 'leet edit <id>' manually"
        return 0
    fi

    echo ""
    echo "Opening problem $id in helix pane..."
    pane_edit "$id"
}

do_test() {
    local id="$1"
    leetcode test "$id"
}

do_submit() {
    local id="$1"
    leetcode exec "$id"
}

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

cmd="$1"
shift

case "$cmd" in
    pick)   [ $# -lt 1 ] && { echo "Usage: $PROG pick <id|slug>" >&2; exit 1; }; do_pick "$1" ;;
    edit)   [ $# -lt 1 ] && { echo "Usage: $PROG edit <id>" >&2; exit 1; }; pane_edit "$1" ;;
    test)   [ $# -lt 1 ] && { echo "Usage: $PROG test <id>" >&2; exit 1; }; do_test "$1" ;;
    submit) [ $# -lt 1 ] && { echo "Usage: $PROG submit <id>" >&2; exit 1; }; do_submit "$1" ;;
    close)  close_pane ;;
    -h|--help|help) usage ;;
    *)      echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac